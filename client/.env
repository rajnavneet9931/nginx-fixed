# =========================
# 🌐 SERVER CONFIG
# =========================
PORT=5000
NODE_ENV=development

# =========================
# 🗄️ DATABASE (Docker Mongo)
# =========================
MONGO_URI=mongodb://mongo:27017/baresober

# =========================
# 🔐 JWT AUTH
# =========================
JWT_SECRET=baresober_super_secret_key_123
JWT_EXPIRE=7d

# =========================
# 👤 ADMIN DEFAULT (optional)
# =========================
ADMIN_EMAIL=admin@baresober.com
ADMIN_PASSWORD=Admin@123

# =========================
# 📁 FILE UPLOAD
# =========================
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5000000

# =========================
# 🌍 FRONTEND URL
# =========================
CLIENT_URL=http://localhost

# =========================
# 📧 EMAIL (optional - for future)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# =========================
# 💳 PAYMENT (optional future)
# =========================
RAZORPAY_KEY_ID=your_key
RAZORPAY_KEY_SECRET=your_secret
